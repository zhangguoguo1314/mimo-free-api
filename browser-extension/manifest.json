{
  "manifest_version": 3,
  "name": "MiMo Cookie 抓取器",
  "version": "2.2.0",
  "description": "一键抓取 MiMo Cookie",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://aistudio.xiaomimimo.com/*",
    "https://*.xiaomimimo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://aistudio.xiaomimimo.com/*",
        "https://*.xiaomimimo.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "点击抓取 MiMo Cookie",
    "default_icon": {
      "16": "icon.svg",
      "48": "icon.svg",
      "128": "icon.svg"
    }
  },
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  }
}
