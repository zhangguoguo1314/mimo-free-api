{
  "manifest_version": 3,
  "name": "MiMo Cookie 抓取器",
  "version": "2.0.0",
  "description": "一键抓取 MiMo Cookie",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://aistudio.xiaomimimo.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.svg",
      "48": "icon.svg",
      "128": "icon.svg"
    }
  },
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  }
}